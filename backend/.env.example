# Copier ce fichier en .env et renseigner les valeurs
# Clé RapidAPI (booking-com.p.rapidapi.com) — https://rapidapi.com
RAPIDAPI_KEY=votre_cle_rapidapi

# Secret de signature des JWT d'authentification (générer une valeur aléatoire longue)
JWT_SECRET=change-me-en-une-valeur-aleatoire-longue
# Durée de validité du token en minutes (défaut 7 jours)
JWT_EXPIRE_MINUTES=10080
